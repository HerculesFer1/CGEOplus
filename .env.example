# ============================================================================
# CGEO+ · Variáveis de Ambiente
# ============================================================================
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA versione .env.local no git.

# ---------------------------------------------------------------------------
# Supabase — obtenha em https://supabase.com/dashboard/project/_/settings/api
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://SEU_PROJETO.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOi..."

# Chave de service_role — SÓ no servidor, nunca exponha ao cliente
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi..."

# ---------------------------------------------------------------------------
# Postgres direto (para migrations Drizzle)
# Use a "Session pooler" ou "Direct connection" do Supabase → Settings → Database
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres.PROJETO:SENHA@aws-0-region.pooler.supabase.com:5432/postgres"

# ---------------------------------------------------------------------------
# Google OAuth (configurado no console Supabase → Authentication → Providers)
# ---------------------------------------------------------------------------
# Nenhuma env necessária aqui — o fluxo é gerido pelo Supabase Auth.
# Apenas cadastre o Client ID no dashboard e adicione a URL de callback:
#   https://SEU_PROJETO.supabase.co/auth/v1/callback

# ---------------------------------------------------------------------------
# Session secret (assina cookie do dev-login)
# Gere uma string aleatória de 32+ chars: `openssl rand -hex 32`
# ---------------------------------------------------------------------------
CGEO_SESSION_SECRET="troque-por-string-aleatoria-de-32-chars-ou-mais"
